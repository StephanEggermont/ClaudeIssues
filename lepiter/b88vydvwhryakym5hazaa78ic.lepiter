				"code" : "view := GtMondrian new.\rview nodes\n\tstencil: [ :month | \n\t\tGtMondrianUMLClassElement withDefaultContainer \r\t\t\tlabel: (month key asString copyFrom: 10 to: 15);\n\t\t\tborder: (BlBorder \r\t\t\t\tpaint: (Color black alpha: 0.5) width: 1)];\n      with: openTimeByMonth associations;\r      forEach: [ :month |\r      \tview nodes\r      \t\tstencil: [ :issues |\r      \t\t\tBlElement new\r      \t\t\t\theight: issues size sqrt;\r      \t\t\t\twidth: issues size sqrt;\r      \t\t\t\tmargin: (BlInsets all: 1);\r      \t\t\t\tbackground: ((issues first at: #closedAt) isNil ifTrue: [Color blue] ifFalse: [Color green])];\r      \t\twith: (month value) .\r      \t\tview layout rectanglePack].\nview layout grid.\rview"
